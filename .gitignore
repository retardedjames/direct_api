# Python
__pycache__/
*.pyc

# 1.8MB binary, easy to re-extract from Waydroid
libs/libmetasec_ov.so

# 23MB TT Lite split-APK bundle, staged here for copying to new Waydroid VMs.
# Don't commit — public repo, and these aren't our bits to redistribute.
ttapk/*.apk

# Per-VM identity files (live cookies + tokens for a single account/device).
# One file per scraper VM, generated by clone_finalize.sh. Never commit.
replay_search_vm*.py

# Local research artifacts moved under HISTORICAL/ (oracles, captured flows,
# Frida traces — all contain real session cookies / signed headers).
HISTORICAL/data/

# Stray local-only files
*.log
